default_provider = "openai"
default_model = "gpt-5.3-codex"
default_temperature = 0.2
provider_timeout_secs = 30

[agent]
max_tool_iterations = 3
max_history_messages = 6

[autonomy]
level = "supervised"
workspace_only = true
allowed_commands = ["*"]
forbidden_paths = []
max_actions_per_hour = 10000
max_cost_per_day_cents = 1000000
auto_approve = ["file_read", "file_write", "file_search", "memory_recall", "memory_store", "http_request", "browser_open", "browser", "browser_screenshot", "spreadsheet_read", "spreadsheet_write", "telegram_send", "screenshot_send", "shell_exec"]
always_ask = ["account_auth", "account_login", "credential_write", "payment", "bank_transfer", "wallet_transfer", "personal_data_read", "personal_data_write", "personal_data_send"]

[gateway]
host = "127.0.0.1"
port = 42617
require_pairing = true
allow_public_bind = false

[channels_config]
cli = true
message_timeout_secs = 60

[channels_config.telegram]
bot_token = "replace_with_telegram_bot_token"
allowed_users = ["*"]
stream_mode = "off"
mention_only = false
interrupt_on_new_message = false

[skills]
prompt_injection_mode = "compact"

[browser]
enabled = true
allowed_domains = ["*"]
backend = "auto"

[http_request]
enabled = true
allowed_domains = ["*"]
max_response_size = 250000
timeout_secs = 30
