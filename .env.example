# ============================================
# Autonomous Branding Agent (ABA) - Environment
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Telegram ---
# Get from @BotFather on Telegram: /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- LLM Provider (SumoPod API) ---
# Get from https://sumopod.com/dashboard/ai/keys
SUMOPOD_API_KEY=sk-your_sumopod_api_key_here

# --- LinkedIn OAuth 2.0 ---
# Create app at https://www.linkedin.com/developers/apps
# Enable "Share on LinkedIn" product for w_member_social scope
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=
# Redirect URI configured in LinkedIn app settings:
LINKEDIN_REDIRECT_URI=http://localhost:3000/callback
